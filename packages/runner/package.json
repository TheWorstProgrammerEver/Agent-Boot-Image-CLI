{
  "name": "@agent-boot/runner",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Private on-image assembly runner.",
  "bin": {
    "agent-boot-codex": "dist/providers/codex/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers/codex": {
      "types": "./dist/providers/codex/index.d.ts",
      "default": "./dist/providers/codex/index.js"
    },
    "./providers/codex/bin": {
      "default": "./dist/providers/codex/bin.js"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@agent-boot/process": "0.0.0",
    "@agent-boot/protocol": "0.0.0"
  }
}
