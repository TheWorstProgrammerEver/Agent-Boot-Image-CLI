{
  "agentId": "my-agent",
  "providers": [],
  "schemaVersion": 1,
  "steps": [
    {
      "command": {
        "arguments": [],
        "executable": "/opt/agent-boot/scripts/prepare"
      },
      "id": "prepare",
      "kind": "automatic"
    },
    {
      "id": "render",
      "kind": "prompt",
