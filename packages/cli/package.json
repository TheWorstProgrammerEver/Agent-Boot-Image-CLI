{
  "name": "@agent-boot/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Host-side Agent Boot command-line composition root.",
  "bin": {
    "create-agent": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./images": {
      "types": "./dist/images/index.d.ts",
      "default": "./dist/images/index.js"
    },
    "./image": {
      "types": "./dist/image/index.d.ts",
      "default": "./dist/image/index.js"
    },
    "./imaging": {
      "types": "./dist/imaging/index.d.ts",
      "default": "./dist/imaging/index.js"
    },
    "./customize": {
      "types": "./dist/customize/index.d.ts",
      "default": "./dist/customize/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "dependencies": {
    "@agent-boot/assembly": "0.0.0",
    "@agent-boot/definition": "0.0.0",
    "@agent-boot/os-adapters": "0.0.0",
    "@agent-boot/os-linux": "0.0.0",
    "@agent-boot/process": "0.0.0",
    "@agent-boot/protocol": "0.0.0",
    "@agent-boot/runner": "0.0.0",
    "@agent-boot/runner-bundle": "0.0.0",
    "@agent-boot/synth": "0.0.0"
  }
}
