{
  "schemaVersion": 1,
  "definitionUrl": "file:///workspace/examples/definitive-agent/definition.ts",
  "agent": {
    "id": "my-agent",
    "displayName": "My Agent"
  },
  "operatingSystem": {
    "catalogId": "raspberry-pi-os-lite-trixie-arm64",
    "compatibility": {
      "architecture": "arm64",
      "boards": [
        "raspberry-pi-5"
      ]
    }
  },
  "account": {
    "username": "my-user",
    "initialPassword": {
      "secretId": "account-authentication"
    }
  },
  "network": {
    "hostname": "my-agent",
    "wifi": {
      "ssid": "<network-ssid>",
      "passphrase": {
        "secretId": "network-authentication"
      }
    }
  },
  "assets": [],
  "prompts": [
    {
      "kind": "prompt",
      "id": "bootstrap-agent",
      "source": {
        "kind": "local",
        "url": "file:///workspace/examples/definitive-agent/prompts/bootstrap-agent.md"
      },
      "variables": [
        "agent-name"
      ]
    }
  ],
  "scripts": [],
  "secrets": [
    {
      "kind": "secret",
      "id": "account-authentication",
      "source": {
        "kind": "local",
        "url": "file:///workspace/examples/definitive-agent/secrets/account-authentication"
      }
    },
    {
      "kind": "secret",
      "id": "network-authentication",
      "source": {
        "kind": "local",
        "url": "file:///workspace/examples/definitive-agent/secrets/network-authentication"
      }
    },
    {
      "kind": "secret",
      "id": "repository-credential",
      "source": {
        "kind": "local",
        "url": "file:///workspace/examples/definitive-agent/secrets/repository-credential"
      }
    }
  ],
  "providers": [
    {
      "id": "codex",
      "command": {
        "executable": "codex",
        "arguments": [
          "--profile",
          "agent-boot",
          "--strict-config",
          "exec",
          "--skip-git-repo-check",
          "-"
        ],
        "workingDirectory": {
          "scope": "user-home",
          "path": "workspace"
        }
      },
      "promptTransport": "stdin"
    }
  ],
  "steps": [
    {
      "id": "set-agent-name",
      "kind": "environment",
      "operation": "set",
      "key": "AGENT_NAME",
      "value": "My Agent"
    },
    {
      "id": "enter-bootstrap-mode",
      "kind": "environment",
      "operation": "set",
      "key": "BOOTSTRAP_MODE",
      "value": "true"
    },
    {
      "id": "codex-install",
      "kind": "automatic",
      "command": {
        "executable": "npm",
        "arguments": [
          "install",
          "--global",
          "@openai/codex@0.144.6"
        ],
        "workingDirectory": {
          "scope": "user-home",
          "path": "workspace"
        }
      }
    },
    {
      "id": "codex-verify-version",
      "kind": "automatic",
      "command": {
        "executable": "agent-boot-codex",
        "arguments": [
          "verify-version",
          "--expected",
          "0.144.6"
        ],
        "workingDirectory": {
          "scope": "user-home",
          "path": "workspace"
        }
      }
    },
    {
      "id": "codex-configure-profile",
      "kind": "automatic",
      "command": {
        "executable": "agent-boot-codex",
        "arguments": [
          "configure-profile"
        ],
        "workingDirectory": {
          "scope": "user-home",
          "path": "workspace"
        }
      }
    },
    {
      "id": "codex-verify-profile",
      "kind": "automatic",
      "command": {
        "executable": "agent-boot-codex",
        "arguments": [
          "verify-profile"
        ],
        "workingDirectory": {
          "scope": "user-home",
          "path": "workspace"
        }
      }
    },
    {
      "id": "codex-authenticate-device",
      "kind": "manual",
      "command": {
        "executable": "codex",
        "arguments": [
          "login",
          "--device-auth"
        ],
        "workingDirectory": {
          "scope": "user-home",
          "path": "workspace"
        }
      },
      "completionCheck": {
        "executable": "codex",
        "arguments": [
          "login",
          "status"
        ],
        "workingDirectory": {
          "scope": "user-home",
          "path": "workspace"
        }
      },
      "pollIntervalSeconds": 2
    },
    {
      "id": "start-agent-support-service",
      "kind": "fire-and-forget",
      "command": {
        "executable": "agent-support-service",
        "arguments": [
          "--foreground"
        ]
      },
      "lifetime": "runner"
    },
    {
      "id": "install-repository-credential",
      "kind": "install-user-secret",
      "secretId": "repository-credential",
      "destination": ".config/repository/credential"
    },
    {
      "id": "leave-bootstrap-mode",
      "kind": "environment",
      "operation": "unset",
      "key": "BOOTSTRAP_MODE"
    },
    {
      "id": "render-bootstrap-prompt",
      "kind": "prompt",
      "templateId": "bootstrap-agent",
      "renderedPromptId": "bootstrap-prompt",
      "retention": "ephemeral",
      "variables": [
        {
          "name": "agent-name",
          "source": {
            "kind": "environment",
            "key": "AGENT_NAME"
          }
        }
      ]
    },
    {
      "id": "run-codex-bootstrap",
      "kind": "provider",
      "providerId": "codex",
      "renderedPromptId": "bootstrap-prompt"
    }
  ]
}
